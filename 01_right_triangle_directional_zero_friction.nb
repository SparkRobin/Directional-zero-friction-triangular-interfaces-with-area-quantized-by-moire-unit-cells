     RowBox[{"16", " ", 
      RowBox[{"Cos", "[", 
       RowBox[{
        FractionBox[
         RowBox[{"2", " ", "my", " ", "\[Pi]"}], 
         RowBox[{
          SqrtBox["3"], " ", "R01"}]], "+", 
        RowBox[{"\[Pi]", " ", 
         RowBox[{"FractionalPart", "[", 
          FractionBox["\[Xi]", "2"], "]"}]}]}], "]"}], " ", 
      RowBox[{"Sin", "[", 
       FractionBox[
        RowBox[{"2", " ", "mx", " ", "\[Pi]"}], "R01"], "]"}], " ", 
