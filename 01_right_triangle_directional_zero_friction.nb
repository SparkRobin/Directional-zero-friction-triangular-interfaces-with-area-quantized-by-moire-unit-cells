Notebook[{

Cell[CellGroupData[{
Cell["Right-Triangle Directional Zero-Friction Derivation", "Title"],

Cell[CellGroupData[{

Cell["\<\
This notebook documents the Mathematica derivation used for the 30-degree \
right-triangle flake in the research paper <Tribology International 222, \
112110 (2026)>. The calculation starts from the moire density field, \
integrates it over the translated right-triangle domain, simplifies the \
integer-xi limit, and then reproduces the normalized main-text results in \
Eqs. (2)-(5).\
\>", "Chapter",
 CellChangeTimes->{{3.9877477851568213`*^9, 
  3.98774782270623*^9}},ExpressionUUID->"1f4b6b34-2bb4-4963-be00-\
85709881f3b7"],

Cell["%% 01 Density and Parameters", "Section"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
The density field is the two-wave triangular-lattice expression. The moved \
density fmove[x, y, mx, my, theta, R01] is derived from <Zhang Z. Design of \
Frictionless Interfaces for Moire Layers. Phys Rev Lett 2025; 135>.\
\>", "Subtitle",
 CellChangeTimes->{{3.987747834331992*^9, 3.9877478377687063`*^9}, {
  3.987747901387989*^9, 
  3.9877479240131288`*^9}},ExpressionUUID->"be1ad599-b564-4c67-8046-\
f63aaff4bb52"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";", 
  RowBox[{"$Assumptions", "=", 
   RowBox[{
    RowBox[{"0", "\[LessEqual]", "\[Theta]"}], "&&", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "x", ",", "y", ",", "mx", ",", "my", ",", "R01", ",", "\[Lambda]", ",", 
       "\[Xi]", ",", "\[Gamma]"}], "}"}], "\[Element]", 
     TemplateBox[{},
      "Reals"]}], "&&", 
    RowBox[{"R01", ">", "0"}], "&&", 
    RowBox[{"\[Lambda]", ">", "0"}], "&&", 
    RowBox[{"\[Xi]", ">", "0"}], "&&", 
    RowBox[{
     RowBox[{"Csc", "[", 
      FractionBox["\[Theta]", "2"], "]"}], "\[GreaterEqual]", "1"}], "&&", 
    RowBox[{
     RowBox[{"Cot", "[", 
      FractionBox["\[Theta]", "2"], "]"}], "\[Element]", 
     TemplateBox[{},
      "Reals"]}]}]}]}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"ebcb688b-16f3-49fb-af2e-0912300ff5ee"],

Cell[BoxData[
 RowBox[{
  RowBox[{"0", "\[LessEqual]", "\[Theta]"}], "&&", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
    "x", "|", "y", "|", "mx", "|", "my", "|", "R01", "|", "\[Lambda]", "|", 
     "\[Xi]", "|", "\[Gamma]"}], ")"}], "\[Element]", 
   TemplateBox[{},
    "Reals"]}], "&&", 
  RowBox[{"R01", ">", "0"}], "&&", 
  RowBox[{"\[Lambda]", ">", "0"}], "&&", 
  RowBox[{"\[Xi]", ">", "0"}], "&&", 
  RowBox[{
   RowBox[{"Csc", "[", 
    FractionBox["\[Theta]", "2"], "]"}], "\[GreaterEqual]", "1"}], "&&", 
  RowBox[{
   RowBox[{"Cot", "[", 
    FractionBox["\[Theta]", "2"], "]"}], "\[Element]", 
   TemplateBox[{},
    "Reals"]}]}]], "Output",
 CellChangeTimes->{3.9877369240467653`*^9},
 CellLabel->"Out[1]=",ExpressionUUID->"20242516-39b3-496a-88b7-6255ab1903cb"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"fmove", "[", 
   RowBox[{
   "x_", ",", "y_", ",", "mx_", ",", "my_", ",", "\[Theta]_", ",", "R01_"}], 
   "]"}], ":=", 
  RowBox[{
   RowBox[{"2", " ", 
    RowBox[{"Cos", "[", 
     FractionBox[
      RowBox[{"2", " ", "\[Pi]", " ", 
       RowBox[{"(", 
        RowBox[{"my", "+", 
         RowBox[{"2", " ", "y"}], "-", 
         RowBox[{"mx", " ", 
          RowBox[{"Cot", "[", 
           FractionBox["\[Theta]", "2"], "]"}]}]}], ")"}], " ", 
       RowBox[{"Sin", "[", 
        FractionBox["\[Theta]", "2"], "]"}]}], "R01"], "]"}], " ", 
    RowBox[{"Cos", "[", 
     FractionBox[
      RowBox[{"2", " ", "\[Pi]", " ", 
       RowBox[{"(", 
        RowBox[{"mx", "+", 
         RowBox[{"2", " ", "x"}], "+", 
         RowBox[{"my", " ", 
          RowBox[{"Cot", "[", 
           FractionBox["\[Theta]", "2"], "]"}]}]}], ")"}], " ", 
       RowBox[{"Sin", "[", 
        FractionBox["\[Theta]", "2"], "]"}]}], 
      RowBox[{
       SqrtBox["3"], " ", "R01"}]], "]"}]}], "+", 
   RowBox[{"Cos", "[", 
    FractionBox[
     RowBox[{"4", " ", "\[Pi]", " ", 
      RowBox[{"(", 
       RowBox[{"mx", "+", 
        RowBox[{"2", " ", "x"}], "+", 
        RowBox[{"my", " ", 
         RowBox[{"Cot", "[", 
          FractionBox["\[Theta]", "2"], "]"}]}]}], ")"}], " ", 
      RowBox[{"Sin", "[", 
       FractionBox["\[Theta]", "2"], "]"}]}], 
     RowBox[{
      SqrtBox["3"], " ", "R01"}]], "]"}]}]}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"08728924-125f-4dc1-b37e-2151e31e04ee"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[Lambda]0", "[", 
    RowBox[{"\[Theta]0_", ",", "R01_"}], "]"}], ":=", 
   FractionBox["R01", 
    RowBox[{"2", " ", 
     RowBox[{"Sin", "[", 
      FractionBox["\[Theta]0", "2"], "]"}]}]]}], ";", 
  RowBox[{"LatticeConstant", "=", 
   RowBox[{"1.42`", " ", 
    SqrtBox["3"]}]}], ";", 
  RowBox[{"\[Theta]0", "=", 
   RowBox[{"10", " ", "\[Degree]"}]}], ";"}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"76dc14d8-9596-4bfd-9454-bcd5fbc17657"],

Cell[CellGroupData[{

Cell["%% 02 Area Relation", "Section"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SRightTriangle", "=", 
   FractionBox[
    RowBox[{
     SqrtBox["3"], " ", "\[Xi]", " ", "\[Lambda]", " ", "3", " ", "\[Xi]", 
     " ", "\[Lambda]"}], 
    RowBox[{"2", " ", "2", " ", "2"}]]}], ";", 
  RowBox[{"SCompleteMoire", "=", 
   FractionBox[
    RowBox[{
     SqrtBox["3"], " ", 
     SuperscriptBox["\[Lambda]", "2"]}], "2"]}], ";"}]], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"2d7fa892-06f2-4d00-a8ee-b1f7a9914f60"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  FractionBox["SRightTriangle", "SCompleteMoire"], "]"}]], "Input",
 CellLabel->"In[6]:=",ExpressionUUID->"7e15cd08-b823-4179-b6a3-f80f3859cf5f"],

Cell[BoxData[
 FractionBox[
  RowBox[{"3", " ", 
   SuperscriptBox["\[Xi]", "2"]}], "4"]], "Output",
 CellChangeTimes->{3.987736924205165*^9},
 CellLabel->"Out[6]=",ExpressionUUID->"1d7df6b1-d0d7-45a2-86ad-c03d18a391d4"]
}, Open  ]]
}, Open  ]],

Cell["%% 03 Geometry Check Plot", "Section"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
The moved density is shown only inside the 30-degree right-triangle \
integration domain.\
\>", "Subtitle",
 CellChangeTimes->{{3.9877479314969873`*^9, 
  3.987747932579465*^9}},ExpressionUUID->"0d0e8932-f604-4333-8955-\
4c396577d108"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Xi]0", "=", "2"}], ";"}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"ac066e53-7110-4b9f-b1e3-5b78500e2d07"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DensityPlot", "[", 
  RowBox[{
   RowBox[{"fmove", "[", 
    RowBox[{
    "x", ",", "y", ",", "0", ",", "0", ",", "\[Theta]0", ",", 
     "LatticeConstant"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      SqrtBox["3"], " ", "\[Xi]0", " ", 
      RowBox[{"\[Lambda]0", "[", 
       RowBox[{"\[Theta]0", ",", "LatticeConstant"}], "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", "0", ",", 
     RowBox[{
      FractionBox["3", "2"], " ", "\[Xi]0", " ", 
      RowBox[{"\[Lambda]0", "[", 
       RowBox[{"\[Theta]0", ",", "LatticeConstant"}], "]"}]}]}], "}"}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", "Automatic"}], ",", 
   RowBox[{"ColorFunction", "\[Rule]", "\"\<Rainbow\>\""}], ",", 
   RowBox[{"MaxRecursion", "\[Rule]", "3"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
   RowBox[{"RegionFunction", "\[Rule]", 
    RowBox[{"Function", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", 
      RowBox[{"y", "<", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          SqrtBox["3"]}], " ", "x"}], "+", 
        RowBox[{
         FractionBox["3", "2"], " ", "\[Xi]0", " ", 
         RowBox[{"\[Lambda]0", "[", 
          RowBox[{"\[Theta]0", ",", "LatticeConstant"}], "]"}]}]}]}]}], 
     "]"}]}], ",", 
   RowBox[{"AspectRatio", "\[Rule]", "Automatic"}]}], "]"}]], "Input",
 CellLabel->"In[8]:=",ExpressionUUID->"8af93212-7b26-400e-b504-31f225c130ac"],

