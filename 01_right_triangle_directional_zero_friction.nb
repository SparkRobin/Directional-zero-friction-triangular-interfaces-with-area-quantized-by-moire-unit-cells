Cell["%% 05 Integer xi: From Eq. S2 to Eq. S3", "Section"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
When xi is an integer, Sin[pi xi] and Sin[2 pi xi] vanish, Cos[2 pi xi] \
becomes one, and FractionalPart[xi] becomes zero. The only remaining parity \
information is FractionalPart[xi/2], which is zero for even xi and one-half \
for odd xi.\
\>", "Subtitle",ExpressionUUID->"fea5ce6a-dc65-4e36-a287-8e28f2a864a0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"integerRules", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"\[Pi]", " ", "\[Xi]"}], "]"}], "\[Rule]", "0"}], ",", 
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"2", " ", "\[Pi]", " ", "\[Xi]"}], "]"}], "\[Rule]", "0"}], 
     ",", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{"2", " ", "\[Pi]", " ", "\[Xi]"}], "]"}], "\[Rule]", "1"}], 
     ",", 
     RowBox[{
      RowBox[{"FractionalPart", "[", "\[Xi]", "]"}], "\[Rule]", "0"}]}], 
    "}"}]}], ";"}]], "Input",
 CellLabel->"In[12]:=",ExpressionUUID->"39028ea7-1f23-4046-b6ed-776fe0017772"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"eqS2IntegerStep", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{"ARtri\[Xi]30", "[", 
     RowBox[{"mx", ",", "my", ",", "\[Lambda]", ",", "\[Xi]"}], "]"}], "/.", 
    "\[VeryThinSpace]", "integerRules"}], "]"}]}]], "Input",
 CellLabel->"In[13]:=",ExpressionUUID->"b8017344-84a2-4d74-964b-8a944ea789e0"],

