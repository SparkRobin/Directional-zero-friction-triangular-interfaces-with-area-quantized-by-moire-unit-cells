 FractionBox[
  RowBox[{
   SqrtBox["3"], " ", 
   SuperscriptBox["\[Lambda]", "2"], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"3", " ", 
      RowBox[{"Cos", "[", 
       FractionBox[
        RowBox[{"4", " ", "my", " ", "\[Pi]"}], 
        RowBox[{
         SqrtBox["3"], " ", "R01"}]], "]"}]}], "-", 
     RowBox[{"3", " ", 
