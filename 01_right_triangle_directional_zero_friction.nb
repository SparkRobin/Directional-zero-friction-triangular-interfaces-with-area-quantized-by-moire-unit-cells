Cell["%% 04 Eq. S2 General Energy", "Section"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Integrate the translated density over the 30-degree right-triangle domain. \
This calculation step will take a long time.\
\>", "Subtitle",
 CellChangeTimes->{{3.987747951386034*^9, 
  3.9877479661810675`*^9}},ExpressionUUID->"135e2873-be51-4e7a-90fb-\
3dc1da719adf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ARtri\[Xi]30Initial", "[", 
   RowBox[{"mx_", ",", "my_", ",", "\[Theta]_", ",", "\[Xi]_"}], "]"}], "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      SqrtBox["3"], " ", "\[Xi]", " ", 
      RowBox[{"\[Lambda]0", "[", 
       RowBox[{"\[Theta]", ",", "R01"}], "]"}]}]], 
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", 
      RowBox[{
       FractionBox["3", "2"], " ", "\[Xi]", " ", 
       RowBox[{"\[Lambda]0", "[", 
        RowBox[{"\[Theta]", ",", "R01"}], "]"}]}]], 
     RowBox[{
      RowBox[{
       RowBox[{"fmove", "[", 
        RowBox[{
        "x", ",", "y", ",", "mx", ",", "my", ",", "\[Theta]", ",", "R01"}], 
        "]"}], " ", 
       RowBox[{"Boole", "[", 
        RowBox[{"y", "<", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            SqrtBox["3"]}], " ", "x"}], "+", 
          RowBox[{
           FractionBox["3", "2"], " ", "\[Xi]", " ", 
           RowBox[{"\[Lambda]0", "[", 
            RowBox[{"\[Theta]", ",", "R01"}], "]"}]}]}]}], "]"}]}], 
      RowBox[{"\[DifferentialD]", "y"}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}]}], "]"}]}]], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"3a1c2cbc-a5ad-478c-8a26-fa0ebed34600"],

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox["\[Integral]", "0", 
   RowBox[{
    FractionBox["1", "4"], " ", 
    SqrtBox["3"], " ", "R01", " ", "\[Xi]", " ", 
    RowBox[{"Csc", "[", 
     FractionBox["\[Theta]", "2"], "]"}]}]], 
  RowBox[{
   SubsuperscriptBox["\[Integral]", "0", 
    RowBox[{
     FractionBox["3", "4"], " ", "R01", " ", "\[Xi]", " ", 
     RowBox[{"Csc", "[", 
      FractionBox["\[Theta]", "2"], "]"}]}]], 
   RowBox[{
    RowBox[{
     RowBox[{"Boole", "[", 
      RowBox[{
       RowBox[{"4", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           SqrtBox["3"], " ", "x"}], "+", "y"}], ")"}]}], "<", 
       RowBox[{"3", " ", "R01", " ", "\[Xi]", " ", 
        RowBox[{"Csc", "[", 
         FractionBox["\[Theta]", "2"], "]"}]}]}], "]"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", 
        RowBox[{"Cos", "[", 
         FractionBox[
          RowBox[{"2", " ", "\[Pi]", " ", 
           RowBox[{"(", 
            RowBox[{"my", "+", 
             RowBox[{"2", " ", "y"}], "-", 
             RowBox[{"mx", " ", 
              RowBox[{"Cot", "[", 
               FractionBox["\[Theta]", "2"], "]"}]}]}], ")"}], " ", 
           RowBox[{"Sin", "[", 
            FractionBox["\[Theta]", "2"], "]"}]}], "R01"], "]"}], " ", 
        RowBox[{"Cos", "[", 
         FractionBox[
          RowBox[{"2", " ", "\[Pi]", " ", 
           RowBox[{"(", 
            RowBox[{"mx", "+", 
             RowBox[{"2", " ", "x"}], "+", 
             RowBox[{"my", " ", 
              RowBox[{"Cot", "[", 
               FractionBox["\[Theta]", "2"], "]"}]}]}], ")"}], " ", 
           RowBox[{"Sin", "[", 
            FractionBox["\[Theta]", "2"], "]"}]}], 
          RowBox[{
           SqrtBox["3"], " ", "R01"}]], "]"}]}], "+", 
       RowBox[{"Cos", "[", 
        FractionBox[
         RowBox[{"4", " ", "\[Pi]", " ", 
          RowBox[{"(", 
           RowBox[{"mx", "+", 
            RowBox[{"2", " ", "x"}], "+", 
            RowBox[{"my", " ", 
             RowBox[{"Cot", "[", 
              FractionBox["\[Theta]", "2"], "]"}]}]}], ")"}], " ", 
          RowBox[{"Sin", "[", 
           FractionBox["\[Theta]", "2"], "]"}]}], 
         RowBox[{
          SqrtBox["3"], " ", "R01"}]], "]"}]}], ")"}]}], 
